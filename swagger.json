{
  "swagger": "2.0",
  "info": {
    "title": "Pick-and-Play API",
    "description": "Pick-and-Play API",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "paths": {
    "/movies/": {
      "get": {
        "description": "Gets all the movies from MongoDB.",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400" : {
            "description": "Could not get list"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "description": "Creates a new movie.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "example": "any"
                },
                "genre": {
                  "example": "any"
                },
                "rating": {
                  "example": "any"
                },
                "runtime": {
                  "example": "any"
                },
                "description": {
                  "example": "any"
                },
                "imageURL": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "412" : {
            "description": "Validation Errors"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/movies/{id}": {
      "get": {
        "description": "Gets a specific movie from MongoDB",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400" : {
            "description": "Invalid Movie ID"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "put": {
        "description": "Updates a specific movie's information or movie review.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "example": "any"
                },
                "genre": {
                  "example": "any"
                },
                "rating": {
                  "example": "any"
                },
                "runtime": {
                  "example": "any"
                },
                "description": {
                  "example": "any"
                },
                "imageURL": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400" : {
            "description": "Invalid ID"
          },
          "412" : {
            "description": "Validation Errors"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "description": "Deletes a specific movie from MongoDB",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400" : {
            "description": "Invalid ID"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}